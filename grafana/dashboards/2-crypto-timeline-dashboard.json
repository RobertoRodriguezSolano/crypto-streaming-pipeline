          "rawSql": "SELECT\n  timestamp AS \"time\",\n  MAX(CASE WHEN crypto_id = 'bitcoin'     THEN change_24h_percent END) AS \"Bitcoin\",\n  MAX(CASE WHEN crypto_id = 'ethereum'    THEN change_24h_percent END) AS \"Ethereum\",\n  MAX(CASE WHEN crypto_id = 'solana'      THEN change_24h_percent END) AS \"Solana\",\n  MAX(CASE WHEN crypto_id = 'cardano'     THEN change_24h_percent END) AS \"Cardano\",\n  MAX(CASE WHEN crypto_id = 'ripple'      THEN change_24h_percent END) AS \"Ripple\",\n  MAX(CASE WHEN crypto_id = 'dogecoin'    THEN change_24h_percent END) AS \"Dogecoin\",\n  MAX(CASE WHEN crypto_id = 'polkadot'    THEN change_24h_percent END) AS \"Polkadot\",\n  MAX(CASE WHEN crypto_id = 'chainlink'   THEN change_24h_percent END) AS \"Chainlink\",\n  MAX(CASE WHEN crypto_id = 'polygon'     THEN change_24h_percent END) AS \"Polygon\",\n  MAX(CASE WHEN crypto_id = 'avalanche-2' THEN change_24h_percent END) AS \"Avalanche\"\nFROM crypto_prices\nWHERE $__timeFilter(timestamp)\nGROUP BY timestamp\nORDER BY timestamp ASC",
