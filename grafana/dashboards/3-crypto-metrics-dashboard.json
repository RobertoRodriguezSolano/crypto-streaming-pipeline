          "editorMode": "code",
          "format": "table",
          "rawQuery": true,
          "rawSql": "WITH price_stats AS (\n  SELECT\n    crypto_id,\n    AVG(price_usd)                                        AS avg_price,\n    STDDEV(price_usd)                                     AS stddev_price\n  FROM crypto_prices\n  WHERE timestamp >= NOW() - INTERVAL '24 hours'\n  GROUP BY crypto_id\n)\nSELECT\n  UPPER(crypto_id)                                        AS \"Crypto\",\n  ROUND((stddev_price / NULLIF(avg_price, 0)) * 100, 4)  AS \"Volatility (CV %)\"\nFROM price_stats\nORDER BY \"Volatility (CV %)\" DESC",
          "refId": "A",
          "sql": {
            "columns": [
              {
                "parameters": [],
                "type": "function"
              }
            ],
            "groupBy": [
              {
