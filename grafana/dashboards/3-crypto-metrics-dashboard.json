          },
          "editorMode": "code",
          "format": "table",
          "rawQuery": true,
          "rawSql": "WITH latest AS (\n  SELECT DISTINCT ON (crypto_id)\n    crypto_id,\n    price_usd,\n    market_cap_usd,\n    volume_24h_usd,\n    change_24h_percent\n  FROM crypto_prices\n  ORDER BY crypto_id, timestamp DESC\n)\nSELECT\n  RANK() OVER (ORDER BY market_cap_usd DESC) AS \"#\",\n  UPPER(crypto_id)                            AS \"Crypto\",\n  price_usd                                   AS \"Price USD\",\n  change_24h_percent                          AS \"24h Change %\",\n  market_cap_usd                              AS \"Market Cap (USD)\",\n  volume_24h_usd                              AS \"Volume 24h\",\n  ROUND((volume_24h_usd / NULLIF(market_cap_usd, 0)) * 100, 2) AS \"Vol/MCap %\"\nFROM latest\nORDER BY market_cap_usd DESC",
          "refId": "A",
          "sql": {
            "columns": [
              {
                "parameters": [],
                "type": "function"
              }
            ],
            "groupBy": [
              {
                "property": {
                  "type": "string"
                },
                "type": "groupBy"
              }
            ],
            "limit": 50
          }
        }
      ],
      "title": "Market Ranking by Market Cap",
