          "editorMode": "code",
          "format": "table",
          "rawQuery": true,
          "rawSql": "WITH latest AS (\n  SELECT DISTINCT ON (crypto_id)\n    crypto_id,\n    market_cap_usd\n  FROM crypto_prices\n  ORDER BY crypto_id, timestamp DESC\n)\nSELECT\n  MAX(CASE WHEN crypto_id = 'bitcoin'                 THEN market_cap_usd END) AS \"Bitcoin\",\n  MAX(CASE WHEN crypto_id = 'ethereum'                THEN market_cap_usd END) AS \"Ethereum\",\n  MAX(CASE WHEN crypto_id = 'solana'                  THEN market_cap_usd END) AS \"Solana\",\n  MAX(CASE WHEN crypto_id = 'ripple'                  THEN market_cap_usd END) AS \"Ripple\",\n  MAX(CASE WHEN crypto_id = 'cardano'                 THEN market_cap_usd END) AS \"Cardano\",\n  MAX(CASE WHEN crypto_id = 'avalanche-2'             THEN market_cap_usd END) AS \"Avalanche\",\n  MAX(CASE WHEN crypto_id = 'dogecoin'                THEN market_cap_usd END) AS \"Dogecoin\",\n  MAX(CASE WHEN crypto_id = 'polkadot'                THEN market_cap_usd END) AS \"Polkadot\",\n  MAX(CASE WHEN crypto_id = 'chainlink'               THEN market_cap_usd END) AS \"Chainlink\",\n  MAX(CASE WHEN crypto_id = 'polygon-ecosystem-token' THEN market_cap_usd END) AS \"POL\"\nFROM latest",
          "refId": "A",
