          "format": "time_series",
          "rawQuery": true,
          "rawSql": "WITH first_price AS (\n  SELECT\n    crypto_id,\n    FIRST_VALUE(price_usd) OVER (\n      PARTITION BY crypto_id\n      ORDER BY timestamp ASC\n    ) AS first_price\n  FROM crypto_prices\n  WHERE $__timeFilter(timestamp)\n),\nbase AS (\n  SELECT DISTINCT ON (crypto_id) crypto_id, first_price FROM first_price\n)\nSELECT\n  cp.timestamp AS \"time\",\n  MAX(CASE WHEN cp.crypto_id = 'bitcoin'     THEN ROUND(((cp.price_usd - b.first_price) / NULLIF(b.first_price,0))*100, 4) END) AS \"Bitcoin\",\n  MAX(CASE WHEN cp.crypto_id = 'ethereum'    THEN ROUND(((cp.price_usd - b.first_price) / NULLIF(b.first_price,0))*100, 4) END) AS \"Ethereum\",\n  MAX(CASE WHEN cp.crypto_id = 'solana'      THEN ROUND(((cp.price_usd - b.first_price) / NULLIF(b.first_price,0))*100, 4) END) AS \"Solana\",\n  MAX(CASE WHEN cp.crypto_id = 'cardano'     THEN ROUND(((cp.price_usd - b.first_price) / NULLIF(b.first_price,0))*100, 4) END) AS \"Cardano\",\n  MAX(CASE WHEN cp.crypto_id = 'avalanche-2' THEN ROUND(((cp.price_usd - b.first_price) / NULLIF(b.first_price,0))*100, 4) END) AS \"Avalanche\",\n  MAX(CASE WHEN cp.crypto_id = 'ripple'      THEN ROUND(((cp.price_usd - b.first_price) / NULLIF(b.first_price,0))*100, 4) END) AS \"Ripple\"\nFROM crypto_prices cp\nJOIN base b ON cp.crypto_id = b.crypto_id\nWHERE $__timeFilter(cp.timestamp)\nGROUP BY cp.timestamp\nORDER BY cp.timestamp ASC",
