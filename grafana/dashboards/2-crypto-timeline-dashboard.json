      "targets": [
        {
          "datasource": {
            "type": "postgres",
            "uid": "af307819-362b-411e-bb9e-3cbc7f2c8028"
          },
          "editorMode": "code",
          "format": "time_series",
          "rawQuery": true,
          "rawSql": "WITH base AS (\n  SELECT\n    crypto_id,\n    FIRST_VALUE(price_usd) OVER (\n      PARTITION BY crypto_id ORDER BY timestamp ASC\n    ) AS first_price\n  FROM crypto_prices\n  WHERE $__timeFilter(timestamp)\n),\nbase_distinct AS (\n  SELECT DISTINCT ON (crypto_id) crypto_id, first_price FROM base\n)\nSELECT\n  cp.timestamp AS \"time\",\n  MAX(CASE WHEN cp.crypto_id = 'bitcoin'     THEN ROUND(((cp.price_usd - b.first_price) / NULLIF(b.first_price,0))*100, 4) END) AS \"Bitcoin\",\n  MAX(CASE WHEN cp.crypto_id = 'ethereum'    THEN ROUND(((cp.price_usd - b.first_price) / NULLIF(b.first_price,0))*100, 4) END) AS \"Ethereum\",\n  MAX(CASE WHEN cp.crypto_id = 'solana'      THEN ROUND(((cp.price_usd - b.first_price) / NULLIF(b.first_price,0))*100, 4) END) AS \"Solana\",\n  MAX(CASE WHEN cp.crypto_id = 'ripple'      THEN ROUND(((cp.price_usd - b.first_price) / NULLIF(b.first_price,0))*100, 4) END) AS \"Ripple\",\n  MAX(CASE WHEN cp.crypto_id = 'cardano'     THEN ROUND(((cp.price_usd - b.first_price) / NULLIF(b.first_price,0))*100, 4) END) AS \"Cardano\",\n  MAX(CASE WHEN cp.crypto_id = 'dogecoin'    THEN ROUND(((cp.price_usd - b.first_price) / NULLIF(b.first_price,0))*100, 4) END) AS \"Dogecoin\",\n  MAX(CASE WHEN cp.crypto_id = 'avalanche-2' THEN ROUND(((cp.price_usd - b.first_price) / NULLIF(b.first_price,0))*100, 4) END) AS \"Avalanche\",\n  MAX(CASE WHEN cp.crypto_id = 'polkadot'    THEN ROUND(((cp.price_usd - b.first_price) / NULLIF(b.first_price,0))*100, 4) END) AS \"Polkadot\",\n  MAX(CASE WHEN cp.crypto_id = 'chainlink'   THEN ROUND(((cp.price_usd - b.first_price) / NULLIF(b.first_price,0))*100, 4) END) AS \"Chainlink\",\n  MAX(CASE WHEN cp.crypto_id = 'polygon-ecosystem-token'     THEN ROUND(((cp.price_usd - b.first_price) / NULLIF(b.first_price,0))*100, 4) END) AS \"Polygon\"\nFROM crypto_prices cp\nJOIN base_distinct b ON cp.crypto_id = b.crypto_id\nWHERE $__timeFilter(cp.timestamp)\nGROUP BY cp.timestamp\nORDER BY cp.timestamp ASC",
          "refId": "A",
          "sql": {
            "columns": [
              {
                "parameters": [],
                "type": "function"
              }
            ],
