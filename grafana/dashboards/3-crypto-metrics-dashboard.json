      "targets": [
        {
          "datasource": {
            "type": "postgres",
            "uid": "af307819-362b-411e-bb9e-3cbc7f2c8028"
          },
          "editorMode": "code",
          "format": "time_series",
          "rawQuery": true,
          "rawSql": "WITH windowed AS (\n  SELECT\n    crypto_id,\n    timestamp,\n    price_usd,\n    STDDEV(price_usd) OVER (\n      PARTITION BY crypto_id\n      ORDER BY timestamp\n      ROWS BETWEEN 9 PRECEDING AND CURRENT ROW\n    ) AS rolling_stddev,\n    AVG(price_usd) OVER (\n      PARTITION BY crypto_id\n      ORDER BY timestamp\n      ROWS BETWEEN 9 PRECEDING AND CURRENT ROW\n    ) AS rolling_avg\n  FROM crypto_prices\n  WHERE $__timeFilter(timestamp)\n    AND crypto_id IN ('bitcoin', 'ethereum', 'solana', 'avalanche-2')\n)\nSELECT\n  timestamp AS \"time\",\n  MAX(CASE WHEN crypto_id = 'bitcoin'     THEN ROUND((rolling_stddev / NULLIF(rolling_avg,0))*100, 4) END) AS \"Bitcoin\",\n  MAX(CASE WHEN crypto_id = 'ethereum'    THEN ROUND((rolling_stddev / NULLIF(rolling_avg,0))*100, 4) END) AS \"Ethereum\",\n  MAX(CASE WHEN crypto_id = 'solana'      THEN ROUND((rolling_stddev / NULLIF(rolling_avg,0))*100, 4) END) AS \"Solana\",\n  MAX(CASE WHEN crypto_id = 'avalanche-2' THEN ROUND((rolling_stddev / NULLIF(rolling_avg,0))*100, 4) END) AS \"Avalanche\"\nFROM windowed\nGROUP BY timestamp\nORDER BY timestamp ASC",
          "refId": "A",
          "sql": {
            "columns": [
              {
                "parameters": [],
                "type": "function"
              }
            ],
            "groupBy": [
              {
                "property": {
                  "type": "string"
                },
                "type": "groupBy"
              }
            ],
            "limit": 50
          }
        }
      ],
      "title": "Rolling Volatility (10 samples) — Bitcoin / Ethereum / Solana / Avalanche",
      "type": "timeseries"
